# ── Database (Neon serverless Postgres) ─────────────────────────────
# Local dev works with any Postgres connection string (Neon or local).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Auth.js ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-32-byte-random-secret

# Seed admin account (created by `npm run db:seed`)
ADMIN_EMAIL=admin@afterlight.local
ADMIN_PASSWORD=change-me-before-seeding

# ── Cron / job endpoints (used from M1 on) ──────────────────────────
# Bearer token that Vercel Cron sends to /api/jobs/* endpoints.
CRON_SECRET=replace-with-a-random-secret

# ── External APIs (documented now, used from M1/M2) ─────────────────
# KALSHI_API_KEY_ID=
# KALSHI_API_PRIVATE_KEY=
# TAVILY_API_KEY=
# ANTHROPIC_API_KEY=
